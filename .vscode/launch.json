{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web (Next.js)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "env": {
        "NODE_OPTIONS": "--inspect=0",
        "NEXT_DIST_DIR": ".next-vscode",
        "API_URL": "http://127.0.0.1:5001",
        "PORT": "3001"
      },
      "restart": true,
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "API (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "cwd": "${workspaceFolder}/services/api",
      "python": "${workspaceFolder}/services/api/.venv/bin/python",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--host", "0.0.0.0", "--port", "5001"],
      "env": {
        "MC_API_ENV": "dev",
        "MC_API_CORS_ORIGINS": "[\"http://localhost:3000\",\"http://127.0.0.1:3000\",\"http://localhost:3100\",\"http://localhost:3001\",\"http://127.0.0.1:3001\",\"http://100.106.117.41:3001\"]"
      },
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Web + API)",
      "configurations": ["Web (Next.js)", "API (FastAPI)"]
    }
  ]
}
