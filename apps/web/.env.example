# Mission Control Web — environment variables
# Copy to .env.local and fill in values

# API base URL (used by dashboard and planning pages)
# Use relative /api in browser; Next rewrites proxy to API_URL target.
NEXT_PUBLIC_API_URL=/api

# Dev server defaults
# Local manual dev should use its own dist dir so it can run alongside always-on dev/prod.
API_URL=http://127.0.0.1:5001
NEXT_DIST_DIR=.next-local
MC_WEB_HOST=
