# Mission Control PROD env (full containers)
NODE_ENV=production

# Host port mapping (compose reads these)
MC_PROD_WEB_PORT=3100
MC_PROD_API_PORT=5100
MC_PROD_POSTGRES_PORT=5432

# Internal app ports inside containers
MC_WEB_INTERNAL_PORT=3000
MC_API_INTERNAL_PORT=5100
MC_WORKER_INTERNAL_PORT=8000

# Database
MC_POSTGRES_DB=mission_control
MC_POSTGRES_USER=mission_control
MC_POSTGRES_PASSWORD=change_me
MC_PROD_POSTGRES_VOLUME_NAME=mission-control-prod_postgres-data
MC_API_POSTGRES_DSN=postgresql+psycopg://mission_control:change_me@postgres:5432/mission_control

# Web proxy target (inside docker network)
API_URL=http://api:5100
NEXT_PUBLIC_API_URL=/api

# API CORS (prod + localhost diagnostics)
MC_API_CORS_ORIGINS=["http://localhost:3100","http://127.0.0.1:3100"]

# Dapr / worker
MC_DAPR_VERSION=1.14.4
MC_WORKER_PUBLISH_INTERVAL_SECONDS=15
MC_API_CONTROL_PLANE_COMMANDS_ENABLED=true
MC_API_CONTROL_PLANE_DAPR_INGEST_ENABLED=true
MC_API_CONTROL_PLANE_WATCHDOG_ENABLED=true

# Secrets / integrations
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# OpenClaw dispatch (control plane)
MC_API_OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
MC_API_OPENCLAW_DEVICE_AUTH_DIR=/run/secrets/openclaw-auth
