# Mission Control DEV env (host-run web/api)
# WEB: npm run dev -- --port 3000
# API: poetry run uvicorn app.main:app --reload --port 5000

NODE_ENV=development

# Web -> API proxy target for next.config.ts rewrites
API_URL=http://127.0.0.1:5000
NEXT_PUBLIC_API_URL=/api

# CLI default for local dev
MC_API_BASE_URL=http://127.0.0.1:5000

# API CORS for local dev
MC_API_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# DB defaults (for API settings)
MC_API_DB_ENGINE=postgres
MC_API_POSTGRES_DSN=postgresql://mission_control:mission_control_dev@127.0.0.1:5432/mission_control

# Optional Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
