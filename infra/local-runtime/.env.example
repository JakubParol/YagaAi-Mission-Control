# Local runtime defaults
MC_API_PORT=5001
MC_WEB_PORT=3000
MC_DAPR_VERSION=1.14.4
MC_DAPR_COMPONENTS_PATH=./dapr/components
MC_WORKER_PUBLISH_INTERVAL_SECONDS=15
MC_API_ORCHESTRATION_COMMANDS_ENABLED=true
MC_API_ORCHESTRATION_DAPR_INGEST_ENABLED=true
MC_API_ORCHESTRATION_WATCHDOG_ENABLED=true

# PostgreSQL defaults
MC_POSTGRES_PORT=5432
MC_POSTGRES_DB=mission_control
MC_POSTGRES_USER=mission_control
MC_POSTGRES_PASSWORD=mission_control_dev
