# Mission Control API — environment variables
# Copy to .env.local for local development overrides.
# Production uses /home/kuba/mission-control/mission-control.env via systemd.

# Database (required) — MC_API_DB_PATH has priority over MC_DB_PATH
# Local dev target:
# MC_DB_PATH=/home/kuba/repos/mission-control/data/mission-control.db
MC_API_DB_PATH=

# Optional OpenClaw config path for /v1/planning/agents/sync
# Defaults to ~/.openclaw/openclaw.json
MC_API_OPENCLAW_CONFIG_PATH=

# Langfuse credentials — falls back to LANGFUSE_* from shared env
MC_API_LANGFUSE_HOST=
MC_API_LANGFUSE_PUBLIC_KEY=
MC_API_LANGFUSE_SECRET_KEY=

# CORS origins (comma-separated)
MC_API_CORS_ORIGINS=["http://localhost:3000","http://localhost:3100"]
