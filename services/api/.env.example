# Mission Control API — environment variables
# Copy to .env.local for local development overrides.
# Production uses /home/kuba/mission-control/mission-control.env via systemd.

# PostgreSQL DSN.
# Migrations are applied out-of-process with: alembic upgrade head
# Example (always-on DEV Postgres via docker compose):
# MC_API_POSTGRES_DSN=postgresql+psycopg://mission_control:mission_control_dev@127.0.0.1:55432/mission_control
MC_API_POSTGRES_DSN=
MC_API_DB_POOL_SIZE=10
MC_API_DB_MAX_OVERFLOW=20

# Optional OpenClaw config path for /v1/planning/agents/sync
# Defaults to ~/.openclaw/openclaw.json
MC_API_OPENCLAW_CONFIG_PATH=

# Langfuse credentials — falls back to LANGFUSE_* from shared env
MC_API_LANGFUSE_HOST=
MC_API_LANGFUSE_PUBLIC_KEY=
MC_API_LANGFUSE_SECRET_KEY=

# CORS origins (comma-separated)
MC_API_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3100","http://localhost:3001","http://127.0.0.1:3001"]

# Orchestration Redis stream contract (MC-371)
MC_API_CONTROL_PLANE_STREAM_PREFIX=mc:control-plane
MC_API_CONTROL_PLANE_STREAM_VERSION=1
MC_API_CONTROL_PLANE_STREAM_PARTITIONS=8
MC_API_CONTROL_PLANE_WORKER_CONSUMER_GROUP=control-plane-workers-v1
MC_API_CONTROL_PLANE_WATCHDOG_CONSUMER_GROUP=control-plane-watchdog-v1
MC_API_CONTROL_PLANE_RETRY_MAX_ATTEMPTS=5
MC_API_CONTROL_PLANE_RETRY_BASE_BACKOFF_SECONDS=5
MC_API_CONTROL_PLANE_RETRY_MAX_BACKOFF_SECONDS=300
MC_API_CONTROL_PLANE_COMMANDS_ENABLED=true
MC_API_CONTROL_PLANE_DAPR_INGEST_ENABLED=true
MC_API_CONTROL_PLANE_WATCHDOG_ENABLED=true
