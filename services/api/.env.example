# Mission Control API — environment variables
# Copy to .env.local for local development overrides.
# Production uses /home/kuba/mission-control/mission-control.env via systemd.

# Database engine selection (Phase 2 migration bootstrap)
# sqlite (current default) or postgres (schema bootstrap only for now)
MC_API_DB_ENGINE=sqlite

# SQLite path (required when engine=sqlite) — MC_API_DB_PATH has priority over MC_DB_PATH
# Local dev target:
# MC_DB_PATH=/home/kuba/repos/mission-control/data/mission-control.db
MC_API_DB_PATH=

# PostgreSQL DSN (required when engine=postgres)
# Example:
# MC_API_POSTGRES_DSN=postgresql://mission_control:mission_control_dev@127.0.0.1:5432/mission_control
MC_API_POSTGRES_DSN=

# Optional OpenClaw config path for /v1/planning/agents/sync
# Defaults to ~/.openclaw/openclaw.json
MC_API_OPENCLAW_CONFIG_PATH=

# Langfuse credentials — falls back to LANGFUSE_* from shared env
MC_API_LANGFUSE_HOST=
MC_API_LANGFUSE_PUBLIC_KEY=
MC_API_LANGFUSE_SECRET_KEY=

# CORS origins (comma-separated)
MC_API_CORS_ORIGINS=["http://localhost:3000","http://localhost:3100"]

# Orchestration Redis stream contract (MC-371)
MC_API_ORCHESTRATION_STREAM_PREFIX=mc:orchestration
MC_API_ORCHESTRATION_STREAM_VERSION=1
MC_API_ORCHESTRATION_STREAM_PARTITIONS=8
MC_API_ORCHESTRATION_WORKER_CONSUMER_GROUP=orchestration-workers-v1
MC_API_ORCHESTRATION_WATCHDOG_CONSUMER_GROUP=orchestration-watchdog-v1
MC_API_ORCHESTRATION_RETRY_MAX_ATTEMPTS=5
MC_API_ORCHESTRATION_RETRY_BASE_BACKOFF_SECONDS=5
MC_API_ORCHESTRATION_RETRY_MAX_BACKOFF_SECONDS=300
MC_API_ORCHESTRATION_COMMANDS_ENABLED=true
MC_API_ORCHESTRATION_DAPR_INGEST_ENABLED=true
MC_API_ORCHESTRATION_WATCHDOG_ENABLED=true
